NODE_ENV=development
PORT=5302

DB_HOST=localhost
# 本工程 Docker 映射宿主机 3310（106 上 3309 已被 jiuyoumi-mysql 占用；与 Vino 3308 区分）
DB_PORT=3310
DB_NAME=vino_db
DB_USER=root
DB_PASSWORD=vino_secret_2024

# 表名前缀：避免该工程意外读取到其他工程的同库数据
TABLE_PREFIX=zkwl_

JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# 邮箱验证码（QQ 邮箱示例：需开启 SMTP 并使用“授权码”，不是登录密码）
EMAIL_ENABLED=true
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=587
EMAIL_USERNAME=your@qq.com
EMAIL_PASSWORD=cmzltsrhmqfcbaia
EMAIL_FROM=your@qq.com
EMAIL_FROM_NAME=智科未来

# 网页绑定商品页域名（库存导出二维码链接、绑定二维码）
FRONTEND_URL=http://localhost:5301

# 微信支付 APIv3（小程序 JSAPI，未配置则无法调起支付）
# WECHAT_PAY_MCH_ID=
# WECHAT_PAY_SERIAL_NO=
# WECHAT_PAY_API_V3_KEY=
# WECHAT_PAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

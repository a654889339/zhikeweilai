.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

.chat-body {
  flex: 1;
  padding: 20rpx 24rpx;
  overflow-y: auto;
}

.chat-hint {
  text-align: center;
  color: #bbb;
  font-size: 26rpx;
  padding: 60rpx 0;
}

.chat-loading {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 40rpx 0;
}

.msg-row {
  display: flex;
  margin-bottom: 28rpx;
  align-items: flex-start;
}

.msg-right {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 600;
}

.avatar-user {
  background: #B91C1C;
  color: #fff;
  margin-left: 16rpx;
}

.avatar-admin {
  background: #e5e7eb;
  color: #6b7280;
  margin-right: 16rpx;
}

.msg-bubble-wrap {
  max-width: 70%;
}

.msg-bubble {
  padding: 18rpx 28rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
}

.bubble-user {
  background: #B91C1C;
  color: #fff;
  border-top-right-radius: 8rpx;
}

.bubble-admin {
  background: #fff;
  color: #333;
  border: 1rpx solid #eee;
  border-top-left-radius: 8rpx;
}

.msg-time {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 6rpx;
  display: block;
}

.msg-right .msg-time {
  text-align: right;
}

.chat-img {
  max-width: 360rpx;
  border-radius: 12rpx;
}

.bubble-img {
  padding: 8rpx !important;
  background: transparent !important;
  border: none !important;
}

.chat-input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  gap: 16rpx;
}

.chat-img-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.chat-send-btn {
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #B91C1C;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 36rpx;
  white-space: nowrap;
}

.chat-send-btn.disabled {
  background: #ddd;
  color: #999;
}

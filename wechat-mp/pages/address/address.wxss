.page { padding: 20rpx; background: transparent; min-height: 100vh; }
.empty { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #999; }
.addr-card { background: #fff; border-radius: 16rpx; margin-bottom: 20rpx; overflow: hidden; }
.addr-main { padding: 24rpx 30rpx; }
.addr-top { display: flex; align-items: center; gap: 16rpx; margin-bottom: 12rpx; }
.addr-name { font-size: 30rpx; font-weight: 600; }
.addr-phone { font-size: 26rpx; color: #666; }
.addr-tag { font-size: 20rpx; color: #B91C1C; border: 1rpx solid #B91C1C; border-radius: 6rpx; padding: 2rpx 10rpx; }
.addr-detail { font-size: 26rpx; color: #666; line-height: 1.5; }
.addr-actions { display: flex; justify-content: flex-end; gap: 30rpx; padding: 16rpx 30rpx; border-top: 1rpx solid #f0f0f0; }
.addr-action { font-size: 24rpx; color: #666; }
.addr-action.danger { color: #B91C1C; }
.add-btn { text-align: center; padding: 24rpx; background: #B91C1C; color: #fff; border-radius: 16rpx; font-size: 30rpx; font-weight: 500; margin-top: 20rpx; }

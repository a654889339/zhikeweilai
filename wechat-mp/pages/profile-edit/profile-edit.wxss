.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 10rpx 30rpx;
}

.edit-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.edit-row:last-child {
  border-bottom: none;
}

.edit-label {
  font-size: 28rpx;
  color: #333;
  width: 160rpx;
  flex-shrink: 0;
}

.edit-avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 1;
}

.edit-avatar-btn::after {
  border: none;
}

.avatar-preview {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: block;
}

.edit-btn-text {
  font-size: 26rpx;
  color: #B91C1C;
}

.edit-nickname-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #666;
  margin-left: 24rpx;
}

.edit-row-phone {
  flex-wrap: wrap;
}

.phone-masked {
  font-size: 28rpx;
  color: #666;
}

.edit-link {
  font-size: 26rpx;
  color: #B91C1C;
  margin-left: 16rpx;
}

.bind-phone-inline {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
  width: 100%;
  margin-top: 8rpx;
}

.bind-phone-input,
.bind-code-input {
  width: 180rpx;
  height: 56rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
}

.btn-get-code,
.btn-bind-phone {
  padding: 0 20rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
  border: none;
}

.btn-get-code {
  background: #f5f5f5;
  color: #666;
}

.btn-get-code[disabled] {
  color: #999;
}

.btn-bind-phone {
  background: #B91C1C;
  color: #fff;
}

.btn-get-code::after,
.btn-bind-phone::after {
  border: none;
}

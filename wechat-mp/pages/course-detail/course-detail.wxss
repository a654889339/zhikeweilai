.page {
  min-height: 100vh;
  background: #f3f4f6;
}
.loading,
.empty {
  padding: 48px;
  text-align: center;
  color: #6b7280;
}
.body {
  max-height: 100vh;
}
.cover {
  width: 100%;
  display: block;
  background: #e5e7eb;
}
.pad {
  padding: 12px 14px 32px;
}
.title {
  font-size: 20px;
  font-weight: 700;
  color: #111827;
  display: block;
  margin-bottom: 8px;
}
.sub {
  font-size: 14px;
  color: #6b7280;
  display: block;
  margin-bottom: 12px;
}
.desc {
  font-size: 15px;
  line-height: 1.6;
  color: #374151;
  margin-bottom: 16px;
}
.vid {
  width: 100%;
  margin-bottom: 12px;
  border-radius: 8px;
  max-height: 220px;
}

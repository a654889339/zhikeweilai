<view class="page">
  <view class="loading-wrap" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
  <block wx:else>
    <view class="detail-cover">
      <text class="detail-cover-icon">🔧</text>
    </view>
    <view class="detail-body">
      <text class="detail-title">{{serviceData.title}}</text>
      <text class="detail-desc">{{serviceData.description}}</text>
      <view class="price-row">
        <text class="detail-price">¥{{serviceData.price}}</text>
        <text class="origin-price" wx:if="{{serviceData.originPrice}}">¥{{serviceData.originPrice}}</text>
      </view>

      <view class="section">
        <text class="section-title">服务亮点</text>
        <view class="feature-list">
          <view class="feature-item"><text class="feature-dot">·</text> 品质保障，全部原装配件</view>
          <view class="feature-item"><text class="feature-dot">·</text> 快速响应，2小时内上门</view>
          <view class="feature-item"><text class="feature-dot">·</text> 透明报价，无隐形消费</view>
          <view class="feature-item"><text class="feature-dot">·</text> 售后无忧，90天质保</view>
        </view>
      </view>

      <view class="section">
        <text class="section-title">服务流程</text>
        <view class="steps">
          <text>1. 在线下单</text>
          <text>2. 工程师接单</text>
          <text>3. 上门服务</text>
          <text>4. 验收确认</text>
          <text>5. 完成评价</text>
        </view>
      </view>
    </view>

    <view class="detail-footer">
      <view class="btn-consult" bindtap="onConsult">💬 咨询</view>
      <button class="btn-book" type="default" hover-class="none" bindtap="onBookTap">立即预约</button>
    </view>
  </block>

  <!-- Order Form Modal：catch 阻止遮罩误触关闭；scroll-view 避免键盘与原生 picker 在部分机型上闪退 -->
  <view class="modal-mask" wx:if="{{showOrderForm}}" catchtouchmove="preventTouchMove" catchtap="closeOrderForm">
    <view class="modal-sheet" catchtap="preventClose" catchtouchmove="preventClose">
      <view class="modal-header">
        <text class="modal-title">预约服务</text>
        <text class="modal-close" catchtap="closeOrderForm">×</text>
      </view>
      <view class="order-service-info">
        <view class="order-service-icon">🔧</view>
        <view>
          <text class="order-service-title">{{serviceData.title}}</text>
          <text class="order-service-price">¥{{serviceData.price}}</text>
        </view>
      </view>

      <scroll-view class="modal-scroll" scroll-y show-scrollbar="{{true}}">
        <view class="form-group">
          <text class="form-label">联系人</text>
          <input
            class="form-input"
            placeholder="请输入联系人姓名"
            value="{{contactName}}"
            maxlength="50"
            adjust-position="{{true}}"
            cursor-spacing="24"
            bindinput="inputContactName"
          />
        </view>
        <view class="form-group">
          <text class="form-label">联系电话</text>
          <input
            class="form-input"
            type="digit"
            placeholder="请输入联系电话"
            value="{{contactPhone}}"
            maxlength="11"
            adjust-position="{{true}}"
            cursor-spacing="24"
            bindinput="inputContactPhone"
          />
        </view>

        <view class="form-group">
          <text class="form-label">国家/地区</text>
          <picker mode="selector" range="{{countryList}}" value="{{countryIndex}}" bindchange="onCountryChange">
            <view class="picker-value">{{country || '请选择国家/地区'}}</view>
          </picker>
        </view>

        <view class="form-group" wx:if="{{country === '其他'}}">
          <text class="form-label">自定义国家</text>
          <input class="form-input" placeholder="请输入国家/地区名称" value="{{customCountry}}" maxlength="100" adjust-position="{{true}}" bindinput="inputCustomCountry" />
        </view>

        <view class="form-group" wx:if="{{country === '中国大陆'}}">
          <text class="form-label">省/市/区</text>
          <picker mode="region" value="{{region}}" bindchange="onRegionChange">
            <view class="picker-value">{{region[0] && region[1] ? region[0] + ' ' + region[1] + (region[2] ? ' ' + region[2] : '') : '请选择省市区'}}</view>
          </picker>
        </view>

        <view class="form-group">
          <text class="form-label">详细地址</text>
          <input
            class="form-input"
            placeholder="请输入小区/街道等具体地址"
            value="{{detailAddress}}"
            maxlength="500"
            adjust-position="{{true}}"
            cursor-spacing="24"
            bindinput="inputDetailAddress"
          />
        </view>
        <view class="form-group">
          <text class="form-label">备注</text>
          <textarea
            class="form-textarea"
            placeholder="其他需要说明的事项（选填）"
            value="{{remark}}"
            maxlength="500"
            adjust-position="{{true}}"
            cursor-spacing="24"
            show-confirm-bar="{{false}}"
            bindinput="inputRemark"
          />
        </view>
      </scroll-view>

      <view class="form-submit">
        <view class="order-total">合计：<text class="order-total-price">¥{{serviceData.price}}</text></view>
        <button class="btn-submit" type="default" hover-class="none" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submitOrder">确认预约</button>
      </view>
    </view>
  </view>
</view>

.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

.loading-wrap {
  padding: 200rpx 0;
  text-align: center;
  color: #999;
}

.detail-cover {
  height: 360rpx;
  background: linear-gradient(135deg, #B91C1C, #7F1D1D);
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-cover-icon {
  font-size: 100rpx;
}

.detail-body {
  background: #fff;
  margin-top: -40rpx;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
}

.detail-title {
  font-size: 40rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.detail-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: block;
  margin-bottom: 24rpx;
}

.price-row {
  margin-bottom: 32rpx;
}

.detail-price {
  font-size: 48rpx;
  font-weight: 700;
  color: #B91C1C;
  margin-right: 16rpx;
}

.origin-price {
  font-size: 28rpx;
  color: #ccc;
  text-decoration: line-through;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 20rpx;
}

.feature-list {
  font-size: 26rpx;
  color: #666;
  line-height: 2;
}

.feature-item {
  display: flex;
  align-items: flex-start;
}

.feature-dot {
  color: #B91C1C;
  margin-right: 8rpx;
}

.steps {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.detail-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.btn-consult {
  width: 120rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid #ddd;
  border-radius: 44rpx;
  flex-shrink: 0;
}

.btn-book {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #B91C1C;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  text-align: center;
  padding: 0;
  margin: 0;
}

/* Modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
}

.modal-sheet {
  width: 100%;
  max-height: 88vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.modal-scroll {
  flex: 1;
  max-height: 52vh;
  min-height: 200rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.order-service-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.order-service-icon {
  width: 88rpx;
  height: 88rpx;
  background: #B91C1C;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.order-service-title {
  font-size: 30rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.order-service-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #B91C1C;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.form-input {
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.form-textarea {
  min-height: 120rpx;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.picker-value {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.picker-value::before {
  content: '';
}

.form-submit {
  margin-top: 32rpx;
}

.order-total {
  font-size: 28rpx;
  text-align: right;
  margin-bottom: 20rpx;
}

.order-total-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #B91C1C;
  margin-left: 8rpx;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #B91C1C;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  text-align: center;
  padding: 0;
  margin: 0;
  border: none;
}

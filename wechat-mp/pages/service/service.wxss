.page {
  min-height: 100vh;
}

.page-title {
  background: rgba(232, 232, 237, 0.5);
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  padding: 24rpx 0;
  color: #1a1a1a;
}

.tabs {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
}

.tab-item.active {
  color: #B91C1C;
  font-weight: 600;
  border-bottom-color: #B91C1C;
}

.service-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  justify-content: space-between;
}

.grid-item {
  width: 48%;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.grid-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.grid-emoji {
  font-size: 44rpx;
}

.grid-name {
  font-size: 30rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 6rpx;
}

.grid-desc {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.grid-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #B91C1C;
}

.guide-section {
  background: #fff;
  padding: 30rpx 24rpx 20rpx;
  margin-bottom: 16rpx;
}

.guide-header {
  margin-bottom: 24rpx;
}

.guide-title {
  font-size: 34rpx;
  font-weight: 600;
}

.guide-scroll {
  white-space: nowrap;
}

.guide-card {
  display: inline-block;
  min-width: 240rpx;
  margin-right: 20rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
}

.guide-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  position: relative;
}

.guide-icon-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
}

.guide-emoji {
  font-size: 44rpx;
}

.guide-badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  background: #B91C1C;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.guide-name {
  font-size: 26rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 6rpx;
}

.guide-model {
  font-size: 22rpx;
  color: #999;
}

.loading-wrap {
  padding: 80rpx 0;
  text-align: center;
  color: #999;
}

.tab-bar-placeholder {
  height: 120rpx;
}

.page {
  min-height: 100vh;
  background: #f3f4f6;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}
.head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: #fff;
  border-bottom: 1rpx solid #e5e7eb;
}
.title {
  font-size: 34rpx;
  font-weight: 600;
}
.btn-new {
  background: #b91c1c !important;
  color: #fff !important;
}
.search-wrap {
  padding: 16rpx 24rpx;
  background: #fff;
}
.search {
  background: #f9fafb;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}
.create-panel {
  margin: 16rpx 24rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
}
.create-input {
  border: 1rpx solid #e5e7eb;
  padding: 16rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}
.create-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}
.list {
  flex: 1;
  padding: 16rpx 24rpx 120rpx;
  box-sizing: border-box;
}
.item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.item-name {
  font-size: 30rpx;
  font-weight: 500;
}
.item-id {
  font-size: 24rpx;
  color: #6b7280;
}
.empty {
  text-align: center;
  padding: 80rpx;
  color: #9ca3af;
  font-size: 28rpx;
}

<view class="page">
  <view class="products-search-wrap">
    <view class="products-search-inner">
      <text class="products-search-icon">🔍</text>
      <input class="products-search-input" placeholder="搜索实验材料" disabled="true" />
    </view>
  </view>

  <view class="products-layout-mp" wx:if="{{sidebarItems.length}}">
    <scroll-view scroll-y class="product-sidebar-mp">
      <view
        class="sidebar-item-mp {{item.rowActive ? 'active' : ''}} {{item.isSub ? 'sub' : ''}} {{item.isHeader ? 'header' : ''}} {{item.isProduct ? 'product-sub' : ''}}"
        wx:for="{{visibleSidebarItems}}"
        wx:key="rowKey"
        data-idx="{{index}}"
        bindtap="selectCategory"
      >
        <text class="sidebar-name-mp">{{item.name}}</text>
      </view>
    </scroll-view>

    <scroll-view scroll-y class="product-main-mp product-main-scroll">
      <view wx:if="{{loading}}" class="loading">加载中...</view>

      <block wx:elif="{{guide.id}}">
        <view class="hero-block">
          <view class="hero" style="background:{{guide.gradient || '#333'}}">
            <image wx:if="{{guide.coverImage}}" src="{{guide.coverImage}}" class="hero-img" mode="aspectFill" bindtap="previewCover" />
            <view wx:else class="hero-fallback">
              <image wx:if="{{guide.iconUrl}}" src="{{guide.iconUrl}}" class="hero-icon-img" />
              <text wx:else class="hero-emoji">{{guide.emoji}}</text>
              <text class="hero-name">{{guide.name}}</text>
            </view>
            <view wx:if="{{guide.showcaseVideo}}" class="play-btn" bindtap="playShowcase">▶</view>
          </view>
          <view wx:if="{{mediaItems.length}}" class="hero-media">
            <text class="hero-media-title">{{firstMediaTitle}}</text>
            <scroll-view scroll-x class="media-scroll">
              <view wx:for="{{mediaItems}}" wx:key="index" class="media-card" bindtap="openMedia" data-item="{{item}}" data-index="{{index}}">
                <view class="media-thumb-wrap">
                  <image wx:if="{{item.thumb}}" src="{{item.thumb}}" class="media-thumb" mode="aspectFill" />
                  <view wx:else class="media-placeholder">{{item.type === 'video' ? '🎬' : '🖼'}}</view>
                  <view wx:if="{{item.type === 'video'}}" class="media-play">▶</view>
                  <view class="media-label-overlay">
                    <text>{{item.title}}</text>
                  </view>
                </view>
              </view>
            </scroll-view>
          </view>
        </view>

        <view class="price-row-mp">
          <text class="pr-label">价格</text>
          <text class="pr-val">¥ {{priceText}}</text>
          <text class="pr-label">积分</text>
          <text class="pr-pts">{{pointsText}}</text>
        </view>

        <view wx:if="{{helpItems.length || sections.length}}" class="card">
          <text class="title">使用帮助</text>
          <view wx:if="{{helpItems.length}}" class="help-row" bindtap="goManual">
            <text class="help-title">电子说明书</text>
            <text class="help-arrow">›</text>
          </view>
          <view wx:if="{{sections.length}}" class="help-row" bindtap="goMaintenance">
            <text class="help-title">常见问题与保养建议</text>
            <text class="help-arrow">›</text>
          </view>
        </view>
      </block>

      <view wx:elif="{{!loading}}" class="empty-hint">
        <text>请在左侧选择种类与商品</text>
      </view>
    </scroll-view>
  </view>

  <view class="footer-shell" wx:if="{{sidebarItems.length && guide.id}}">
    <view class="footer-inner">
      <button class="fb-btn fb-cart" bindtap="goCart">购物车</button>
      <button class="fb-btn fb-add" bindtap="addToCart">加入购物车</button>
      <button class="fb-btn fb-buy" bindtap="openBuy">立即下单</button>
    </view>
  </view>

  <view wx:if="{{!sidebarItems.length && !loading}}" class="empty-hint">
    <text>暂无商品配置</text>
  </view>

  <view class="tab-bar-placeholder"></view>
</view>

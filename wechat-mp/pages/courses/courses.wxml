<view class="page">
  <view class="products-search-wrap">
    <view class="products-search-inner">
      <text class="products-search-icon">🔍</text>
      <input class="products-search-input" placeholder="搜索课程" value="{{searchKeyword}}" bindinput="onSearchInput" />
    </view>
  </view>

  <view class="products-layout-mp" wx:if="{{sidebarItems.length}}">
    <scroll-view scroll-y class="product-sidebar-mp">
      <view
        class="sidebar-item-mp {{item.rowActive ? 'active' : ''}} {{item.isSub ? 'sub' : ''}} {{item.isHeader ? 'header' : ''}}"
        wx:for="{{visibleSidebarItems}}"
        wx:key="rowKey"
        data-idx="{{index}}"
        bindtap="selectCategory"
      >
        <view class="sidebar-inner-mp" wx:if="{{item.thumb}}">
          <image class="sidebar-thumb-mp" src="{{item.thumb}}" mode="aspectFill" />
          <text class="sidebar-name-mp">{{item.name}}</text>
        </view>
        <text class="sidebar-name-mp only" wx:else>{{item.name}}</text>
      </view>
    </scroll-view>

    <view class="product-main-mp course-main-wrap-mp">
      <picker
        wx:if="{{l2PickerOptions.length > 1}}"
        mode="selector"
        range="{{l2PickerOptions}}"
        range-key="name"
        value="{{l2PickerIndex}}"
        bindchange="onL2Pick"
      >
        <view class="product-select-row">
          <view class="select-product-field">
            <text class="select-label">选择子分类</text>
            <text class="select-value">{{l2PickerLabel}}</text>
            <text class="select-arrow">›</text>
          </view>
        </view>
      </picker>

    <scroll-view scroll-y class="course-main-mp">
      <view wx:if="{{loading}}" class="loading">加载中...</view>
      <view wx:elif="{{filteredCourses.length}}" class="course-grid">
        <view
          class="course-card"
          wx:for="{{filteredCourses}}"
          wx:key="id"
          data-item="{{item}}"
          bindtap="openCourse"
        >
          <image wx:if="{{item.coverImage}}" class="course-cover" src="{{item.coverImageFull}}" mode="aspectFill" />
          <view wx:else class="course-icon-fallback">📚</view>
          <text class="course-name">{{item.name}}</text>
        </view>
      </view>
      <view wx:else class="empty">该分类下暂无课程</view>
    </scroll-view>
    </view>
  </view>

  <view wx:else class="empty-page">暂无课程分类</view>
</view>

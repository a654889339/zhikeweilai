<view class="page">
  <view class="products-search-wrap">
    <view class="products-search-inner">
      <text class="products-search-icon">🔍</text>
      <input class="products-search-input" placeholder="搜索课程" value="{{searchKeyword}}" bindinput="onSearchInput" />
    </view>
  </view>

  <view class="products-layout-mp" wx:if="{{sidebarItems.length}}">
    <scroll-view scroll-y class="product-sidebar-mp">
      <view
        class="sidebar-item-mp {{item.rowActive ? 'active' : ''}} {{item.isSub ? 'sub' : ''}} {{item.isHeader ? 'header' : ''}} {{item.isCourse ? 'product-sub' : ''}}"
        wx:for="{{visibleSidebarItems}}"
        wx:key="rowKey"
        data-idx="{{index}}"
        bindtap="selectCategory"
      >
        <view class="sidebar-inner-mp" wx:if="{{item.thumb}}">
          <image class="sidebar-thumb-mp" src="{{item.thumb}}" mode="aspectFill" />
          <text class="sidebar-name-mp">{{item.name}}</text>
        </view>
        <text class="sidebar-name-mp only" wx:else>{{item.name}}</text>
      </view>
    </scroll-view>

    <scroll-view scroll-y class="product-main-mp course-main-wrap-mp course-main-mp">
      <view wx:if="{{loading}}" class="loading">加载中...</view>
      <block wx:elif="{{course.id}}">
        <image wx:if="{{course.coverImage}}" class="cover" src="{{course.coverFull}}" mode="widthFix" />
        <view class="pad">
          <text class="title">{{course.name}}</text>
          <text wx:if="{{course.subtitle}}" class="sub">{{course.subtitle}}</text>
          <rich-text wx:if="{{course.description}}" nodes="{{course.description}}" class="desc"></rich-text>
          <block wx:for="{{videos}}" wx:for-index="idx" wx:key="idx">
            <video class="vid" src="{{item}}" controls show-center-play-btn></video>
          </block>
        </view>
      </block>
      <view wx:else class="empty">请选择左侧分类与课程</view>
    </scroll-view>
  </view>

  <view wx:else class="empty-page">暂无课程分类</view>
</view>

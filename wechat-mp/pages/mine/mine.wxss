.profile-header {
  padding: 80rpx 40rpx 60rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-img {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
}

.avatar-text {
  font-size: 48rpx;
  color: #fff;
  font-weight: 700;
}

.profile-name {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.profile-desc {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
}

.stats-row {
  display: flex;
  background: #fff;
  padding: 30rpx 0;
  margin-bottom: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 600;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.menu-card {
  background: #fff;
  border-radius: 16rpx;
  margin: 0 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon-img {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.menu-title {
  flex: 1;
  font-size: 28rpx;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.logout-area {
  padding: 40rpx 32rpx;
}

.btn-logout {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  color: #666;
  background: #fff;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  text-align: center;
  padding: 0;
  margin: 0;
}

.tab-bar-placeholder {
  height: 120rpx;
}

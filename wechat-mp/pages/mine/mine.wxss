.page {
  min-height: 100vh;
  background: #f2f2f7;
  padding-bottom: 40rpx;
}

.profile-header {
  padding: 96rpx 48rpx 56rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-img {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
}

.avatar-text {
  font-size: 48rpx;
  color: #fff;
  font-weight: 700;
}

.profile-name {
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.profile-desc {
  color: rgba(255, 255, 255, 0.65);
  font-size: 26rpx;
}

/* 资产条 */
.asset-bar {
  display: flex;
  align-items: stretch;
  background: #fff;
  margin: 0 24rpx 20rpx;
  border-radius: 24rpx;
  padding: 36rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.asset-item {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.asset-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #1d1d1f;
}

.wallet-num {
  font-size: 36rpx;
  color: #b91c1c;
}

.asset-label {
  font-size: 24rpx;
  color: #888;
  font-weight: 500;
}

.asset-divider {
  width: 1rpx;
  background: #eee;
  align-self: stretch;
  margin: 8rpx 0;
}

/* 我的订单 */
.orders-card {
  background: #fff;
  margin: 0 24rpx 20rpx;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.orders-card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.orders-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1d1d1f;
}

.orders-all {
  font-size: 26rpx;
  color: #888;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.orders-all.muted {
  opacity: 0.85;
}

.orders-all-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.orders-shortcuts {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
}

.os-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.os-icon-wrap {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.os-badge {
  position: absolute;
  top: -12rpx;
  right: -20rpx;
  background: #ee0a24;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
  line-height: 1.3;
  z-index: 1;
}

.os-icon {
  font-size: 36rpx;
  font-weight: 600;
  color: #1d1d1f;
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  border-radius: 50%;
  background: #f5f5f7;
}

.os-label {
  font-size: 22rpx;
  color: #888;
  text-align: center;
  line-height: 1.25;
}

/* 功能宫格 */
.tool-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 24rpx 20rpx;
  padding: 28rpx 16rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.tool-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 8rpx;
  box-sizing: border-box;
}

.tool-icon {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #1d1d1f;
  background: #f5f5f7;
  border-radius: 16rpx;
}

.tool-label {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

.menu-card {
  background: #fff;
  border-radius: 24rpx;
  margin: 0 24rpx 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon-img {
  width: 40rpx;
  height: 40rpx;
  margin-right: 24rpx;
}

.menu-title {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.logout-area {
  padding: 40rpx 32rpx;
}

.btn-logout {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  color: #666;
  background: #fff;
  border: 1rpx solid #ddd;
  border-radius: 16rpx;
  text-align: center;
  padding: 0;
  margin: 0;
}

.tab-bar-placeholder {
  height: 120rpx;
}

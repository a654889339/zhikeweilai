<view class="page">
  <view class="form-group">
    <text class="label">联系人</text>
    <input class="input" placeholder="请输入联系人姓名" value="{{contactName}}" bindinput="onInput" data-field="contactName" />
  </view>
  <view class="form-group">
    <text class="label">手机号</text>
    <input class="input" placeholder="请输入手机号" type="number" value="{{contactPhone}}" bindinput="onInput" data-field="contactPhone" />
  </view>
  <view class="form-group">
    <text class="label">国家/地区</text>
    <picker range="{{countries}}" value="{{countryIdx}}" bindchange="onCountry">
      <text class="picker-text">{{country || '请选择'}}</text>
    </picker>
  </view>
  <view class="form-group" wx:if="{{country === '其他'}}">
    <text class="label">自定义国家</text>
    <input class="input" placeholder="请输入国家名称" value="{{customCountry}}" bindinput="onInput" data-field="customCountry" />
  </view>
  <view class="form-group" wx:if="{{country === '中国大陆'}}">
    <text class="label">省市区</text>
    <picker mode="region" bindchange="onRegion">
      <text class="picker-text">{{province ? province + ' ' + city + ' ' + district : '请选择省市区'}}</text>
    </picker>
  </view>
  <view class="form-group">
    <text class="label">详细地址</text>
    <textarea class="textarea" placeholder="请输入详细地址" value="{{detailAddress}}" bindinput="onInput" data-field="detailAddress" />
  </view>
  <view class="form-group row">
    <text class="label">设为默认</text>
    <switch checked="{{isDefault}}" bindchange="onDefault" color="#B91C1C" />
  </view>
  <button class="save-btn" bindtap="save">保存</button>
</view>

<view class="page">
  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <block wx:elif="{{!lines.length}}">
    <view class="cart-empty">
      <text class="cart-empty-icon">🛒</text>
      <text class="cart-empty-text">购物车是空的</text>
      <button class="cart-btn" bindtap="goProducts">去选购</button>
    </view>
  </block>

  <block wx:else>
    <scroll-view scroll-y class="cart-scroll" enhanced show-scrollbar="{{false}}">
      <view wx:for="{{lines}}" wx:key="guideId" class="cart-row">
        <view class="cart-row-main">
          <text class="cart-name">{{item.name}}</text>
          <text class="cart-meta">¥{{item.listPrice}} · 积分{{item.rewardPoints}}</text>
        </view>
        <view class="cart-qty">
          <text class="qty-label">数量</text>
          <input class="qty-input" type="number" value="{{item.qty}}" data-id="{{item.guideId}}" bindinput="onQtyInput" />
        </view>
      </view>
    </scroll-view>

    <view class="cart-bottom">
      <view class="cart-total">
        合计 <text class="cart-total-num">¥ {{totalPrice}}</text>
        <text class="cart-pts"> · 积分 {{totalPoints}}</text>
      </view>
      <button class="cart-submit" bindtap="openCheckout">下单</button>
    </view>
  </block>

  <view wx:if="{{checkoutShow}}" class="mask" bindtap="closeCheckout">
    <view class="panel" catchtap="noop">
      <text class="panel-title">填写联系信息</text>
      <input class="field" placeholder="联系人（必填）" value="{{contactName}}" data-k="contactName" bindinput="onField" />
      <input class="field" type="number" placeholder="电话（必填）" value="{{contactPhone}}" data-k="contactPhone" bindinput="onField" />
      <textarea class="field area" placeholder="地址（选填）" value="{{address}}" data-k="address" bindinput="onField" />
      <textarea class="field area" placeholder="备注（选填）" value="{{remark}}" data-k="remark" bindinput="onField" />
      <view class="panel-btns">
        <button class="btn-cancel" bindtap="closeCheckout">取消</button>
        <button class="btn-ok" loading="{{submitting}}" bindtap="submitOrder">提交订单</button>
      </view>
    </view>
  </view>
</view>

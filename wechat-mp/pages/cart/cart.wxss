.page {
  min-height: 100vh;
  background: #e8e8ed;
  box-sizing: border-box;
  padding-bottom: 120px;
}
.loading {
  text-align: center;
  padding: 80px 0;
  color: #6b7280;
}
.cart-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80px;
}
.cart-empty-icon {
  font-size: 56px;
  margin-bottom: 16px;
}
.cart-empty-text {
  font-size: 15px;
  color: #6b7280;
  margin-bottom: 24px;
}
.cart-btn {
  background: #b91c1c;
  color: #fff;
  border-radius: 999px;
  padding: 12px 48px;
  font-size: 15px;
  border: none;
}
.cart-scroll {
  max-height: calc(100vh - 200px);
  padding: 12px;
  box-sizing: border-box;
}
.cart-row {
  background: #fff;
  border-radius: 12px;
  padding: 14px 16px;
  margin-bottom: 10px;
}
.cart-row-main {
  margin-bottom: 10px;
}
.cart-name {
  font-size: 16px;
  font-weight: 600;
  color: #111;
  display: block;
}
.cart-meta {
  font-size: 12px;
  color: #6b7280;
  margin-top: 4px;
  display: block;
}
.cart-qty {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.qty-label {
  font-size: 13px;
  color: #666;
}
.qty-input {
  width: 80px;
  text-align: center;
  border: 1px solid #ddd;
  border-radius: 8px;
  padding: 6px;
  font-size: 15px;
}
.cart-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1px solid rgba(0, 0, 0, 0.06);
}
.cart-total {
  font-size: 15px;
  margin-bottom: 10px;
  color: #111;
}
.cart-total-num {
  color: #b91c1c;
  font-weight: 700;
  font-size: 20px;
}
.cart-pts {
  font-size: 13px;
  color: #6b7280;
}
.cart-submit {
  width: 100%;
  background: #b91c1c;
  color: #fff;
  border-radius: 999px;
  padding: 12px;
  font-size: 16px;
  font-weight: 600;
  border: none;
}

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #B91C1C 0%, #7F1D1D 40%, #1a1a1a 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 40rpx;
}

.login-card {
  width: 100%;
  max-width: 650rpx;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  border: 3rpx solid rgba(255,255,255,0.3);
}

.logo-text {
  font-size: 64rpx;
  font-weight: 700;
  color: #fff;
}

.logo-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.app-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.app-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
}

.header-logo-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 24rpx;
  text-align: center;
  line-height: 1.5;
  max-width: 500rpx;
}

.btn-wx-login {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #07C160;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  margin-top: 40rpx;
  text-align: center;
  padding: 0;
}

.btn-wx-login::after {
  border: none;
}

.login-tip {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
  margin-top: 24rpx;
}

.profile-setup {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-top: 20rpx;
}

.setup-title {
  display: block;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 36rpx;
}

.avatar-area {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  padding: 0;
  border-radius: 50%;
  overflow: hidden;
  background: #f5f5f5;
  border: none;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx dashed #ccc;
  border-radius: 50%;
}

.avatar-placeholder-text {
  font-size: 22rpx;
  color: #999;
  text-align: center;
}

.nickname-area {
  margin-bottom: 32rpx;
}

.field-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.btn-save {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #B91C1C;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  text-align: center;
  padding: 0;
}

.btn-save::after {
  border: none;
}

.skip-link {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #999;
  margin-top: 20rpx;
  padding: 10rpx 0;
}

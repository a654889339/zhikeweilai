<view class="page">
  <view class="tabs">
    <view
      class="tab-item {{activeTab === index ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <text>{{item.name}}</text>
    </view>
  </view>

  <view class="loading-wrap" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
  <view class="empty-wrap" wx:elif="{{isLoggedIn && !orders.length}}">
    <text>暂无订单</text>
  </view>
  <view class="order-list" wx:else>
    <view class="order-card" wx:for="{{orders}}" wx:key="id">
      <view class="order-header">
        <text class="order-no">{{item.orderNo || item.id}}</text>
        <text class="order-status status-{{item.status}}">{{item.statusText}}</text>
      </view>
      <view class="order-body">
        <view class="order-icon">🔧</view>
        <view class="order-info">
          <text class="order-title">{{item.serviceTitle}}</text>
          <text class="order-time">{{item.timeText}}</text>
          <text class="order-contact" wx:if="{{item.contactName}}">{{item.contactName}} {{item.contactPhone}}</text>
        </view>
        <text class="order-price">¥{{item.price}}</text>
      </view>
      <view class="order-actions" wx:if="{{item.status === 'pending'}}">
        <button class="btn-pay" size="mini" bindtap="payOrder" data-id="{{item.id}}">去支付</button>
        <button class="btn-cancel" size="mini" bindtap="cancelOrder" data-id="{{item.id}}">取消订单</button>
      </view>
    </view>
  </view>

  <view class="login-tip" wx:if="{{!isLoggedIn && !loading}}">
    <text>请先登录查看订单</text>
    <navigator url="/pages/login/login" class="link-login">去登录</navigator>
  </view>

  <view class="tab-bar-placeholder"></view>
</view>

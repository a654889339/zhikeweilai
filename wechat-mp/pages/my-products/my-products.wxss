.page { padding: 20rpx; background: #f7f7f7; min-height: 100vh; }
.add-bar { margin-bottom: 24rpx; }
.add-btn { background: #fff; color: #B91C1C; border: 1rpx solid #B91C1C; border-radius: 40rpx; font-size: 28rpx; }
.empty { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #999; }
.card { background: #fff; border-radius: 16rpx; margin-bottom: 20rpx; padding: 24rpx 30rpx; }
.row { display: flex; justify-content: space-between; align-items: center; padding: 10rpx 0; font-size: 28rpx; }
.row .label { color: #999; min-width: 140rpx; }
.row .value { color: #333; flex: 1; text-align: right; word-break: break-all; }
.row .value.sn { font-family: monospace; font-size: 26rpx; }

.mv-container {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.mv-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

.mv-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.mv-loading {
  color: #fff;
  font-size: 28rpx;
  background: rgba(0,0,0,0.5);
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
}

.mv-error {
  color: #ff6b6b;
  font-size: 24rpx;
  background: rgba(0,0,0,0.6);
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  max-width: 80%;
  text-align: center;
}

.mv-hint {
  position: absolute;
  bottom: 24rpx;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(255,255,255,0.45);
  font-size: 22rpx;
  pointer-events: none;
}

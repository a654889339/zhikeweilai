<view class="tab-bar">
  <view
    class="tab-bar-item {{selected === index ? 'active' : ''}}"
    wx:for="{{list}}"
    wx:key="pagePath"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <image class="tab-icon-img" src="{{selected === index ? item.active : item.normal}}" mode="aspectFit" />
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>

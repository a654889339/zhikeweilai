/* 与页面主内容卡片左右边距一致（约 24rpx ≈ 12px） */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 24rpx;
  right: 24rpx;
  width: auto;
  height: 100rpx;
  max-width: 702rpx;
  margin: 0 auto;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  display: flex;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -1rpx 0 rgba(0, 0, 0, 0.08);
  z-index: 9999;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #999;
}

.tab-bar-item.active {
  color: #B91C1C;
  font-weight: 600;
}

.tab-icon-img {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 22rpx;
}

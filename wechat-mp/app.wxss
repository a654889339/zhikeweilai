page {
  background: linear-gradient(to bottom, #E8E8ED 0%, #F2F2F7 30%, #ffffff 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: #333;
  font-size: 28rpx;
}

.container {
  padding: 20rpx 30rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.primary-color {
  color: #B91C1C;
}
